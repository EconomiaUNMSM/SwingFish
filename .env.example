# 🔱 SwingFish Environment Configuration Template

# --- BACKEND SETTINGS ---
# OpenAI API Key for Multi-Agent Analysis (Required)
OPENAI_API_KEY=your_openai_api_key_here

# FRED API Key (Required for Macro Dashboard)
# Get yours at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Backend Server Configuration
PORT=8000
HOST=0.0.0.0

# --- FRONTEND SETTINGS ---
# URL of the Backend API (Required for the frontend to communicate)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: Environment mode (development/production)
NODE_ENV=development
